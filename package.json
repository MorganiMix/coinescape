{
  "name": "crypto-panic-button",
  "version": "1.0.0",
  "description": "Emergency withdrawal application for cryptocurrency exchanges",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "keywords": [
    "cryptocurrency",
    "emergency",
    "withdrawal",
    "exchange",
    "panic-button"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ccxt": "^4.2.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "fast-check": "^3.15.0",
    "prettier": "^3.2.0"
  }
}
